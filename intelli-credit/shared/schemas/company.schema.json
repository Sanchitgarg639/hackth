{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Company",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": { "type": "string" },
    "sector": { "type": "string", "default": "General" },
    "gstin": { "type": "string", "pattern": "^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[0-9]{1}[A-Z]{1}[0-9A-Z]{1}$" },
    "pan": { "type": "string", "pattern": "^[A-Z]{5}[0-9]{4}[A-Z]{1}$" },
    "address": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" }
  }
}
